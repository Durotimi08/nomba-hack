    "test:watch": "vitest"
  },
  "dependencies": {
    "@kobo/shared": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
