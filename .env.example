# ──────────────────────────────────────────────────────────────────────────
# Kobo — environment template. Copy to `.env` and fill real values.
# NEVER commit a real .env. All vars are validated by Zod at boot (packages/shared/env).
# ──────────────────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
LOG_LEVEL=debug

# API service
API_PORT=3001
# Comma-separated allowlist for CORS (the dashboard origin).
CORS_ORIGINS=http://localhost:3000

# Postgres (system of record). In docker-compose these point at the `postgres` service.
DATABASE_URL=postgres://kobo:kobo@localhost:5432/kobo

# Redis (BullMQ queues + token lease + dashboard cache).
REDIS_URL=redis://localhost:6379

# Schema lifecycle on API boot. Off locally (docker-compose runs a `migrate` job;
# dev runs migrations by hand). Set both to "true" on managed hosts without
# one-off jobs (e.g. Render free tier) so the API migrates + seeds itself.
# Both are idempotent. SEED_ON_BOOT implies MIGRATE_ON_BOOT.
MIGRATE_ON_BOOT=false
SEED_ON_BOOT=false
# Run the reconcile/payout/backfill BullMQ consumers inside the API process
# instead of a separate worker. The zero-cost way to get job processing on a
# single free instance (keep it warm with an external pinger). Leave false when
# running the dedicated @kobo/worker (docker-compose / a paid worker service).
RUN_WORKER_IN_PROCESS=false

# ── Nomba API ──────────────────────────────────────────────────────────────
# Base URL (host only; the client appends /v1,/v2 paths).
# sandbox https://sandbox.nomba.com  |  production https://api.nomba.com
# (note: the training doc's sandbox.api.nomba.com host is NXDOMAIN — do not use it.)
NOMBA_BASE_URL=https://sandbox.nomba.com
NOMBA_CLIENT_ID=
NOMBA_CLIENT_SECRET=
# Parent business UUID — sent as the `accountId` header on every request.
NOMBA_ACCOUNT_ID=
# Optional sub-account UUID. If your dashboard issued a sub-account, set it here:
# VA creation + payouts are scoped to it while the parent stays in the accountId header.
NOMBA_SUB_ACCOUNT_ID=
# Use your TEST client id/secret with the sandbox base URL above (NOT the LIVE pair).
# Signature key from the Nomba dashboard — used to verify the `nomba-signature` webhook header.
NOMBA_SIGNATURE_KEY=
# "real" hits the Nomba sandbox/prod API; "mock" uses the in-memory adapter (hermetic dev/tests).
NOMBA_ADAPTER=mock

# ── Auth (operator console, maker-checker) ─────────────────────────────────
# 32+ byte random secret. Generate: openssl rand -base64 48
JWT_SECRET=
# Access token TTL for operator sessions.
JWT_TTL=1h

# ── Workers ────────────────────────────────────────────────────────────────
# Cron for the missed-webhook backfill poller (default: every 5 minutes).
BACKFILL_CRON=*/5 * * * *
# Reconciliation worker concurrency (per replica).
RECONCILE_CONCURRENCY=8
