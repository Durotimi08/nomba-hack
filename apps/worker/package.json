{
  "name": "@kobo/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/worker.ts",
    "start": "node dist/worker.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:int": "vitest run --config vitest.int.config.ts"
  },
  "dependencies": {
    "@kobo/core": "workspace:*",
    "@kobo/db": "workspace:*",
    "@kobo/nomba": "workspace:*",
    "@kobo/shared": "workspace:*",
    "bullmq": "^5.34.6",
    "drizzle-orm": "^0.38.3",
    "ioredis": "^5.4.2",
    "luxon": "^3.5.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.16.0",
    "@testcontainers/redis": "^10.16.0",
    "@types/luxon": "^3.4.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
