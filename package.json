{
  "name": "kobo",
  "version": "0.1.0",
  "private": true,
  "description": "Kobo — per-customer virtual-account reconciliation engine on the Nomba API",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:int": "pnpm -r test:int",
    "db:generate": "pnpm --filter @kobo/db generate",
    "db:migrate": "pnpm --filter @kobo/db migrate",
    "db:seed": "pnpm --filter @kobo/db seed",
    "simulate": "pnpm --filter @kobo/api simulate --"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0"
  }
}
